generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid())
  username          String             @unique
  email             String             @unique
  password          String
  role              Role               @default(STUDENT)
  createdAt         DateTime           @default(now())
  sessions          Session[]
  passwordResetOtps PasswordResetOtp[]
  enrollments       Enrollment[]
  testAttempts      TestAttempt[]
  feedbacks         Feedback[]
  orders            Order[]
  courses           Course[]
  aiAssessments     AiAssessment[]
  pointTransactions PointTransaction[]
  learningActivities LearningActivity[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetOtp {
  id        String   @id @default(uuid())
  userId     String
  email      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([email, createdAt])
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

model Course {
  id          String       @id @default(uuid())
  name        String
  description String
  thumbnail   String?   
  category    String?      
  duration    String?      
  lessons     Int          @default(0)
  status      CourseStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  price       Float
  instructorId String?     // ID của giảng viên

  instructor  User?        @relation(fields: [instructorId], references: [id])
  modules     Module[]
  enrollments Enrollment[]
  tests       Test[]
  feedbacks   Feedback[]
  orderItems  OrderItem[]
  aiAssessments AiAssessment[]
  pointTransactions PointTransaction[]
  learningActivities LearningActivity[]
}

enum CourseStatus {
  ACTIVE
  LOCKED
}

model Module {
  id       String @id @default(uuid())
  courseId String
  name     String
  order    Int

  course  Course   @relation(fields: [courseId], references: [id])
  lessons Lesson[]
}

model Lesson {
  id       String @id @default(uuid())
  moduleId String
  title    String
  content  String
  videoUrl String?

  module Module @relation(fields: [moduleId], references: [id])
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model Test {
  id           String   @id @default(uuid())
  courseId     String
  name         String
  description String?
  maxScore     Float
  passingScore Float
  maxAttempts  Int
  timeLimit    Int?  
  shuffleQuestions Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course   Course        @relation(fields: [courseId], references: [id])
  attempts TestAttempt[]
  questions Question[]
}

enum QuestionType {
  MULTIPLE_CHOICE  // Trắc nghiệm
  FILL_IN_BLANK    // Điền từ
  ESSAY            // Viết bài văn
  TRUE_FALSE       // Đúng/Sai
}

model Question {
  id           String       @id @default(uuid())
  testId       String
  type         QuestionType
  content      String       // Nội dung câu hỏi
  audioUrl     String?      // URL audio cho câu hỏi listening
  order        Int
  score        Float        // Điểm cho câu này
  explanation  String?     // Giải thích/Lý do đúng
  hint         String?      // Gợi ý
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  test     Test          @relation(fields: [testId], references: [id])
  answers  Answer[]
}

model Answer {
  id         String  @id @default(uuid())
  questionId String
  content    String  // Nội dung đáp án
  isCorrect  Boolean // Đáp án đúng hay sai
  order      Int     // Thứ tự đáp án (đặc biệt quan trọng với trắc nghiệm)
  feedback   String? // Phản hồi khi chọn đáp án này

  question Question @relation(fields: [questionId], references: [id])
}

model TestAttempt {
  id          String   @id @default(uuid())
  testId      String
  userId      String
  attemptNo   Int
  score       Float
  maxScore    Float
  answers     Json?
  results     Json?
  startedAt   DateTime
  submittedAt DateTime
  isPassed    Boolean

  test         Test          @relation(fields: [testId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  cheatingLogs CheatingLog[]

  @@unique([testId, userId, attemptNo])
}

model AiAssessment {
  id              String   @id @default(uuid())
  userId          String
  courseId        String?
  type            String
  title           String?
  prompt          String?
  submissionText  String?
  audioUrl        String?
  durationSeconds Int?
  score           Float
  maxScore        Float    @default(10)
  bandSystem      String
  bandLevel       String
  bandScore       Float
  criteria        Json
  feedback        Json
  mistakes        Json?
  improvements    Json?
  sampleAnswer    String?
  startedAt       DateTime?
  submittedAt     DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id])

  @@index([userId, submittedAt])
  @@index([courseId, submittedAt])
  @@index([type, submittedAt])
}

model PointTransaction {
  id           String   @id @default(uuid())
  userId       String
  courseId     String?
  type         String
  amount       Int
  balanceAfter Int
  sourceKey    String   @unique
  description  String
  metadata     Json?
  createdAt    DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id])

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model LearningActivity {
  id           String   @id @default(uuid())
  userId       String
  courseId     String?
  activityType String
  sourceKey    String   @unique
  activityDate DateTime
  createdAt    DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id])

  @@index([userId, activityDate])
  @@index([activityType, createdAt])
}

model CheatingLog {
  id        String   @id @default(uuid())
  attemptId String
  type      String
  severity  Int
  createdAt DateTime @default(now())

  attempt TestAttempt @relation(fields: [attemptId], references: [id])
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  content   String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())

  user    User       @relation(fields: [userId], references: [id])
  items   OrderItem[]
  payment Payment?
}

model OrderItem {
  id       String @id @default(uuid())
  orderId  String
  courseId String
  price    Float

  order  Order  @relation(fields: [orderId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String   @unique
  amount    Float
  status    String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}
